# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Lightweight default models. You can change these in .env.
OPENROUTER_MODEL_CLASSIFY=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_WRITE=google/gemini-2.5-flash
OPENROUTER_MODEL_REVIEW=google/gemini-2.5-flash-lite

OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=1200

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://github.com/YOUR_GITHUB_USERNAME/pixel-agents-main
OPENROUTER_APP_TITLE=Minwon Pixel Agents

# Optional: send pipeline events to running Pixel Agents server
# Standalone mode example:
# PIXEL_AGENTS_EVENT_URL=http://127.0.0.1:PORT/api/minwon-event
# Embedded mode may require PIXEL_AGENTS_TOKEN.
PIXEL_AGENTS_EVENT_URL=
PIXEL_AGENTS_TOKEN=

# Optional browser demo event endpoint
PIXEL_AGENTS_EVENT_URL=http://127.0.0.1:8787/api/minwon-event
MINWON_DEMO_PORT=8787
